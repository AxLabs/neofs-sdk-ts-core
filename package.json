{
  "name": "@axlabs/neofs-sdk-ts-core",
  "version": "0.0.2",
  "description": "Shared core code for NeoFS TypeScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crypto": {
      "require": "./dist/crypto/index.js",
      "import": "./dist/crypto/index.js",
      "types": "./dist/crypto/index.d.ts"
    },
    "./user": {
      "require": "./dist/user/index.js",
      "import": "./dist/user/index.js",
      "types": "./dist/user/index.d.ts"
    },
    "./types": {
      "require": "./dist/types/index.js",
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./utils": {
      "require": "./dist/utils/index.js",
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp src/utils/closure-polyfill.js dist/utils/ 2>/dev/null || true",
    "build:plugin": "cd protoc-gen-grpc-ts && make build",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "test": "echo 'No tests in core package'",
    "publish:dry-run": "npm publish --dry-run",
    "publish:public": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AxLabs/neofs-sdk-ts-core.git",
    "directory": "neofs-sdk-ts-core"
  },
  "bugs": {
    "url": "https://github.com/AxLabs/neofs-sdk-ts-core/issues"
  },
  "homepage": "https://github.com/AxLabs/neofs-sdk-ts-core#readme",
  "keywords": [
    "neofs",
    "blockchain",
    "storage",
    "typescript",
    "sdk",
    "core"
  ],
  "author": "NeoFS Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/elliptic": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "elliptic": "^6.5.7"
  },
  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "crypto": ["./dist/crypto/index.d.ts"],
      "user": ["./dist/user/index.d.ts"],
      "types": ["./dist/types/index.d.ts"],
      "utils": ["./dist/utils/index.d.ts"]
    }
  }
}
